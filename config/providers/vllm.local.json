{
  "name": "vllm-local",
  "enabled": true,
  "bind_host": "127.0.0.1",
  "port": 8000,
  "base_url": "http://127.0.0.1:8000/v1",
  "model": "Qwen/Qwen2.5-3B-Instruct",
  "startup": {
    "command": "./scripts/start-vllm.sh",
    "timeout_seconds": 180,
    "health_endpoint": "/v1/models",
    "chat_endpoint": "/v1/chat/completions"
  },
  "safety": {
    "localhost_only": true,
    "cloud_disabled": true,
    "hidden_fallback": false
  }
}
