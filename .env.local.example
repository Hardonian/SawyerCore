SAWYER_BIND_HOST=127.0.0.1
SAWYER_PORT=8787
SAWYER_PROFILE=local-safe
SAWYER_PRIVATE_MODE=true
SAWYER_CLOUD_FALLBACK=false

SAWYER_VLLM_ENABLED=true
SAWYER_VLLM_BASE_URL=http://127.0.0.1:8000/v1
SAWYER_VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct

SAWYER_LITELLM_ENABLED=true
SAWYER_LITELLM_BASE_URL=http://127.0.0.1:4000/v1
SAWYER_LITELLM_MODEL=local-qwen

SAWYER_LLAMACPP_ENABLED=false
SAWYER_LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
SAWYER_LLAMACPP_MODEL_PATH=/absolute/path/to/model.gguf

SAWYER_AUDIT_LOG=./logs/sawyer-audit.jsonl
SAWYER_REQUEST_TIMEOUT_MS=30000
SAWYER_MAX_REQUEST_BYTES=1048576
